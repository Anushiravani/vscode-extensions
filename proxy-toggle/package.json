{
  "name": "proxy-toggle",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.5",
  "publisher": "Anushiravani",
  "author": {
    "name": "Pouria Anoushiravani",
    "email": "pouria56@gmail.com",
    "url": "https://github.com/Anushiravani"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0e639c",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other",
    "Productivity",
    "Network"
  ],
  "keywords": [
    "proxy",
    "http proxy",
    "socks",
    "network",
    "toggle",
    "vpn",
    "firewall",
    "corporate proxy",
    "ssl",
    "certificates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anushiravani/vscode-extensions.git"
  },
  "homepage": "https://github.com/Anushiravani/vscode-extensions",
  "bugs": {
    "url": "https://github.com/Anushiravani/vscode-extensions/issues",
    "email": "pouria56@gmail.com"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "proxyToggle.openPanel",
        "title": "%command.openPanel.title%"
      },
      {
        "command": "proxyToggle.openSettings",
        "title": "%command.openSettings.title%"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "proxyTogglePanel",
          "title": "%view.container.title%",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "proxyTogglePanel": [
        {
          "type": "webview",
          "id": "proxyToggle.view",
          "name": "%view.title%",
          "visibility": "hidden"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "proxyToggle.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.enabled.description%",
          "scope": "window"
        },
        "proxyToggle.proxyUrl": {
          "type": "string",
          "default": "http://127.0.0.1:1080",
          "description": "%config.proxyUrl.description%",
          "scope": "window"
        },
        "proxyToggle.proxyAuthorization": {
          "type": "string",
          "default": "",
          "description": "%config.proxyAuthorization.description%",
          "scope": "window"
        },
        "proxyToggle.proxyStrictSSL": {
          "type": "boolean",
          "default": false,
          "description": "%config.proxyStrictSSL.description%",
          "scope": "window"
        },
        "proxyToggle.proxySupport": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "fallback",
            "override"
          ],
          "default": "on",
          "description": "%config.proxySupport.description%",
          "scope": "window"
        },
        "proxyToggle.noProxy": {
          "type": "string",
          "default": "",
          "description": "%config.noProxy.description%",
          "scope": "window"
        },
        "proxyToggle.useLocalProxyConfiguration": {
          "type": "boolean",
          "default": true,
          "description": "%config.useLocalProxyConfiguration.description%",
          "scope": "window"
        },
        "proxyToggle.networkInterfaceCheckInterval": {
          "type": "integer",
          "default": 300,
          "description": "%config.networkInterfaceCheckInterval.description%",
          "scope": "window"
        },
        "proxyToggle.systemCertificatesV2": {
          "type": "boolean",
          "default": false,
          "description": "%config.systemCertificatesV2.description%",
          "scope": "window"
        },
        "proxyToggle.fetchAdditionalSupport": {
          "type": "boolean",
          "default": true,
          "description": "%config.fetchAdditionalSupport.description%",
          "scope": "window"
        },
        "proxyToggle.systemCertificates": {
          "type": "boolean",
          "default": true,
          "description": "%config.systemCertificates.description%",
          "scope": "window"
        },
        "proxyToggle.systemCertificatesNode": {
          "type": "boolean",
          "default": false,
          "description": "%config.systemCertificatesNode.description%",
          "scope": "window"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "proxyToggle.openPanel",
          "when": "true"
        },
        {
          "command": "proxyToggle.openSettings",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "echo \"no build step\""
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0"
  }
}
